				"import os\n",
				"import torch\n",
				"import pandas as pd\n",
				"from PIL import Image\n",
				"from torch.utils.data import Dataset, DataLoader\n",
				"import torchvision.transforms as transforms\n",
				"\n",
				"class ConstellationDataset(Dataset):\n",
				"    def __init__(self, csv_file, img_dir, transform=None):\n",
				"        # Read the master CSV from your Google Drive\n",
				"        self.df = pd.read_csv(csv_file)\n",
				"        self.img_dir = img_dir\n",
				"        self.transform = transform\n",
				"\n",
				"        # 1. Create a stable, sorted mapping for your 14+ modulation types\n",
				"        unique_mods = sorted(self.df['modulation'].unique())\n",
				"        self.mod_mapping = {mod_name: idx for idx, mod_name in enumerate(unique_mods)}\n",
				"\n",
				"        # 2. Map your noise scenarios to clean SNR categories (Low=0, Medium=1, High=2)\n",
				"        # Note: As you mentioned, Mixed_High has an SNR of 5-10dB, which is technically 'Low' SNR performance-wise!\n",
				"        self.snr_mapping = {\"Clean\": 2, \"High\": 2, \"Medium\": 1, \"Low\": 0}\n",
				"\n",
				"    def __len__(self):\n",
				"        return len(self.df)\n",
				"\n",
				"    def __getitem__(self, idx):\n",
				"        row = self.df.iloc[idx]\n",
				"        img_path = os.path.join(self.img_dir, row['path'])\n",
				"        image = Image.open(img_path).convert('RGB')\n",
				"\n",
				"        if self.transform:\n",
				"            image = self.transform(image)\n",
				"\n",
				"        # 1. Modulation Map\n",
				"        mod_label = self.mod_mapping[row['modulation']]\n",
				"\n",
				"        # 2. FIXED SNR/SEVERITY MAPPING\n",
				"        # Map based on the explicit SCENARIO string instead of the snr_level column\n",
				"        scenario_str = row['scenario']\n",
				"\n",
				"        if scenario_str == \"Mixed_High\":\n",
				"            snr_label = 0  # Low Quality / Severe Compound Channel\n",
				"        elif scenario_str in [\"PhaseNoiseOnly\", \"IQImbalanceOnly\", \"JammingOnly\"]:\n",
				"            snr_label = 1  # Medium Quality / Standard Single Impairment\n",
				"        else: # \"Clean\" or \"Mixed_Medium\"\n",
				"            snr_label = 2  # High Quality / Low Distortion\n",
				"\n",
				"        # 3. Impairments\n",
				"        impairments = torch.tensor([\n",
				"            float(row['phase_noise']),\n",
				"            float(row['iq_imbalance']),\n",
				"            float(row['jamming']),\n",
				"            float(row['amplitude_dist'])\n",
				"        ], dtype=torch.float32)\n",
				"\n",
				"        return image, mod_label, snr_label, impairments\n",
				"\n",
				"# --- VERIFY EVERYTHING WORKS ---\n",
				"# Define basic ResNet image transformations\n",
				"transform = transforms.Compose([\n",
				"    transforms.Resize((256, 256)),\n",
				"    transforms.ToTensor(),\n",
				"    transforms.Normalize(mean=[0.485, 0.456, 0.406], std=[0.229, 0.224, 0.225])\n",
				"])\n",
				"\n",
				"# Paths matching your Colab directory structure exactly\n",
				"CSV_PATH = \"/content/drive/MyDrive/Thlep_Project/master_dataset.csv\"\n",
				"IMG_DIR = \"/content/datasets/Images\" # Added the '/Images' subfolder fix here\n",
				"\n",
				"# Initialize the dataset\n",
				"dataset = ConstellationDataset(csv_file=CSV_PATH, img_dir=IMG_DIR, transform=transform)\n",
				"\n",
				"print(f\"Dataset successfully initialized! Total samples found: {len(dataset)}\")\n",
				"print(\"Modulation Mapping dictionary looks like this:\\n\", dataset.mod_mapping)\n",
