				"import torch\n",
				"import torch.nn as nn\n",
				"import torch.optim as optim\n",
				"from torch.utils.data import DataLoader, random_split\n",
				"from torchvision import models\n",
				"\n",
				"# 1. Set Hardware Acceleration to GPU if available\n",
				"device = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
				"print(f\"Using device: {device}\")\n",
				"\n",
				"# 2. Split Dataset into Train (80%) and Validation (20%)\n",
				"train_size = int(0.8 * len(dataset))\n",
				"val_size = len(dataset) - train_size\n",
				"train_dataset, val_dataset = random_split(dataset, [train_size, val_size])\n",
				"\n",
				"# 3. Create DataLoaders (Shuffling is critical for training)\n",
				"train_loader = DataLoader(train_dataset, batch_size=32, shuffle=True, drop_last=False)\n",
				"val_loader = DataLoader(val_dataset, batch_size=32, shuffle=False, drop_last=False)\n",
				"\n",
				"# 4. Define the Multi-Head Network\n",
				"class MultiHeadResNet(nn.Module):\n",
				"    def __init__(self, num_classes_mod=15, num_classes_snr=3):\n",
				"        super(MultiHeadResNet, self).__init__()\n",
				"        # Load pre-trained ResNet-18 backbone\n",
				"        self.backbone = models.resnet18(weights=models.ResNet18_Weights.DEFAULT)\n",
				"        in_features = self.backbone.fc.in_features\n",
				"        self.backbone.fc = nn.Identity() # Remove the single original final layer\n",
				"\n",
				"        # Branch out into 3 custom task layers\n",
				"        self.mod_head = nn.Linear(in_features, num_classes_mod)  # Target: 15 Modulation Classes\n",
				"        self.snr_head = nn.Linear(in_features, num_classes_snr)  # Target: 3 SNR classes (0,1,2)\n",
				"        self.impair_head = nn.Linear(in_features, 4)             # Target: 4 Binary Flags (PN, IQ, Jam, Amp)\n",
				"\n",
				"    def forward(self, x):\n",
				"        features = self.backbone(x)\n",
				"        return {\n",
				"            \"modulation\": self.mod_head(features),\n",
				"            \"snr\": self.snr_head(features),\n",
				"            \"impairments\": self.impair_head(features)\n",
				"        }\n",
				"\n",
				"# Initialize model, loss functions, and optimizer\n",
				"model = MultiHeadResNet().to(device)\n",
				"\n",
				"criterion_ce = nn.CrossEntropyLoss()       # For multi-class heads (Modulation and SNR)\n",
				"criterion_bce = nn.BCEWithLogitsLoss()     # For multi-label binary flags (Impairments)\n",
				"optimizer = optim.Adam(model.parameters(), lr=1e-4)\n",
				"\n",
				"# 5. The Training Loop (Running 5 Epochs as a Baseline)\n",
				"num_epochs = 5\n",
				"print(\"\\n--- Starting CNN Training Baseline ---\")\n",
				"\n",
				"for epoch in range(num_epochs):\n",
				"    model.train()\n",
				"    running_loss = 0.0\n",
				"\n",
				"    for i, (images, mod_labels, snr_labels, impair_targets) in enumerate(train_loader):\n",
				"        # Move data tensors to GPU\n",
				"        images = images.to(device)\n",
				"        mod_labels = mod_labels.to(device)\n",
				"        snr_labels = snr_labels.to(device)\n",
				"        impair_targets = impair_targets.to(device)\n",
				"\n",
				"        # Zero out the parameter gradients\n",
				"        optimizer.zero_grad()\n",
				"\n",
				"        # Forward pass\n",
				"        outputs = model(images)\n",
				"\n",
				"        # Calculate distinct losses for each head\n",
				"        loss_mod = criterion_ce(outputs[\"modulation\"], mod_labels)\n",
				"        loss_snr = criterion_ce(outputs[\"snr\"], snr_labels)\n",
				"        loss_imp = criterion_bce(outputs[\"impairments\"], impair_targets)\n",
				"\n",
				"        # Total combined Multi-Task Loss\n",
				"        total_loss = loss_mod + loss_snr + loss_imp\n",
				"\n",
				"        # Backward pass + Optimization step\n",
				"        total_loss.backward()\n",
				"        optimizer.step()\n",
				"\n",
				"        running_loss += total_loss.item()\n",
				"\n",
				"    print(f\"Epoch [{epoch+1}/{num_epochs}] completed. Average Combined Loss: {running_loss/len(train_loader):.4f}\")\n",
				"\n",
				"print(\"--- CNN Baseline Model Training Complete! ---\")"
			],
